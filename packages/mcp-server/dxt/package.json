{
  "name": "@mux/mcp",
  "version": "12.5.0",
  "description": "The official MCP Server for the Mux API",
  "author": "Mux <devex@mux.com>",
  "types": "./index.d.ts",
  "main": "./index.js",
  "type": "commonjs",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/muxinc/mux-node-sdk.git",
    "directory": "packages/mcp-server"
  },
  "homepage": "https://github.com/muxinc/mux-node-sdk/tree/main/packages/mcp-server#readme",
  "license": "Apache-2.0",
  "packageManager": "yarn@1.22.22",
  "private": false,
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "test": "jest",
    "build": "bash ./build",
    "format": "prettier --write --cache --cache-strategy metadata . !dist",
    "tsn": "ts-node -r tsconfig-paths/register",
    "lint": "eslint --ext ts,js .",
    "fix": "eslint --fix --ext ts,js ."
  },
  "dependencies": {
    "@mux/mux-node": "^12.5.0",
    "@cloudflare/cabidela": "^0.2.4",
    "@modelcontextprotocol/sdk": "^1.11.5",
    "@valtown/deno-http-worker": "^0.0.21",
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "jq-web": "https://github.com/stainless-api/jq-web/releases/download/v0.8.6/jq-web.tar.gz",
    "qs": "^6.14.0",
    "yargs": "^17.7.2",
    "zod": "^3.25.20",
    "zod-to-json-schema": "^3.24.5",
    "zod-validation-error": "^4.0.1"
  },
  "bin": {
    "mcp-server": "./index.js"
  },
  "imports": {
    "@mux/mcp": ".",
    "@mux/mcp/*": "./src/*"
  },
  "exports": {
    ".": {
      "require": "./index.js",
      "default": "./index.mjs"
    },
    "./*.mjs": "./*.mjs",
    "./*.js": "./*.js",
    "./*": {
      "require": "./*.js",
      "default": "./*.mjs"
    }
  }
}